#!/usr/bin/env bash
# ARM objdump launcher (GNU binutils, in OrbStack or a local NDK r18b fallback).
# Fully supports ARMv7-A Thumb-2 + VFP/NEON, unlike objdiff's ARM backend.
# Used by tools/verify/asmdiff.py. Override the machine with GOF2_ORB_MACHINE.
set -euo pipefail
MACHINE="${GOF2_ORB_MACHINE:-ubuntu}"
HERE="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$HERE/../.." && pwd)"

if command -v orb >/dev/null 2>&1 && [ -z "${GOF2_VERIFY_LOCAL_NDK:-}" ]; then
  # stdin from /dev/null: objdump reads none, and it stops `orb` from flipping the shared
  # controlling TTY to raw mode (the parallel disassemble jobs race to restore it and leave the
  # terminal raw, which staircases the report output).
  exec orb -m "$MACHINE" arm-linux-gnueabihf-objdump "$@" </dev/null
fi

NDK="${GOF2_NDK_ROOT:-${NDK:-$REPO/.cache/ndk/android-ndk-r18b}}"
for host in windows-x86_64 linux-x86_64 darwin-x86_64; do
  for exe in arm-linux-androideabi-objdump.exe arm-linux-androideabi-objdump; do
    OBJDUMP="$NDK/toolchains/arm-linux-androideabi-4.9/prebuilt/$host/bin/$exe"
    [ -x "$OBJDUMP" ] && exec "$OBJDUMP" "$@" </dev/null
  done
done

echo "ARM objdump not found. Set GOF2_NDK_ROOT/NDK or install .cache/ndk/android-ndk-r18b." >&2
exit 1
